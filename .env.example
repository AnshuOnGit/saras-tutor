PORT=8080
DATABASE_URL=postgres://saras:saras@localhost:5432/saras_tutor?sslmode=disable

# ── LLM API (OpenAI-compatible endpoint) ──
# NVIDIA NIM:     https://integrate.api.nvidia.com/v1
# OpenRouter:     https://openrouter.ai/api/v1
# OpenAI direct:  https://api.openai.com/v1
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxx
LLM_USER_ID=

# ── Three-tier model setup ──
# Vision: heavy VLM for image extraction
VISION_MODEL=qwen/qwen2-vl-72b-instruct

# Solver: math-strong model for hints + full solutions
SOLVER_MODEL=qwen/qwq-32b

# Router: fast/cheap model for validation, parsing, verification
ROUTER_MODEL=meta/llama-3.1-70b-instruct

# Retry models offered when verifier score is low
RETRY_MODELS=qwen/qwq-32b,deepseek-ai/deepseek-v3_1,meta/llama-3.1-70b-instruct
